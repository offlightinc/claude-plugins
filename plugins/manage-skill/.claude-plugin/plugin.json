{
  "name": "manage-skill",
  "version": "1.0.2",
  "description": "Manage Claude Code extensions (skills, hooks, agents) — create, modify, rename, delete with deployment pipeline",
  "author": {
    "name": "Team Offlight",
    "url": "https://github.com/offlightinc"
  },
  "repository": "https://github.com/offlightinc/claude-plugins",
  "license": "MIT",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/extension-guard.sh"
          }
        ]
      }
    ]
  }
}
